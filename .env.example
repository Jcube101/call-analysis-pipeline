# HuggingFace token — required for pyannote speaker diarization
# Get yours at https://huggingface.co/settings/tokens
# You must also accept the model license at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=your_token_here

# Anthropic API key — reserved for future report generation stage
ANTHROPIC_API_KEY=your_key_here

# Conversation context — affects metadata tagging in output
# Accepted values: friend | work | interview | date
CONVERSATION_CONTEXT=friend

# Number of speakers — set to an integer or leave blank for auto-detection
# Auto-detection works but is less reliable than providing the exact count
NUM_SPEAKERS=2
